{
  "name": "@arduino/react-native-mqtt-client",
  "version": "0.2.7",
  "description": "MQTT client for React Native",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/src/index.d.ts",
  "react-native": "src/index",
  "source": "./src/index.tsx",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "react-native-mqtt-client.podspec",
    "!lib/typescript/example",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build",
    "release": "release-it",
    "example": "yarn --cwd example",
    "pods": "cd example && pod-install --quiet",
    "bootstrap": "yarn example && yarn && yarn pods"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "author": "Arduino (https://github.com/arduino)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arduino/react-native-mqtt-client.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arduino/react-native-mqtt-client/issues"
  },
  "homepage": "https://github.com/arduino/react-native-mqtt-client#readme",
  "devDependencies": {
    "@commitlint/config-conventional": "8.3.4",
    "@react-native/eslint-config": "0.74.87",
    "@release-it/conventional-changelog": "1.1.4",
    "@types/jest": "26.0.15",
    "@types/react": "16.9.56",
    "@types/react-native": "0.62.13",
    "@typescript-eslint/eslint-plugin": "5.57.1",
    "@typescript-eslint/parser": "5.57.1",
    "commitlint": "8.3.5",
    "eslint": "8.19.0",
    "eslint-plugin-ft-flow": "2.0.1",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jest": "26.5.3",
    "husky": "4.3.0",
    "jest": "26.6.3",
    "pod-install": "0.1.12",
    "prettier": "2.8.8",
    "react": "16.11.0",
    "react-native": "0.62.2",
    "react-native-builder-bob": "0.30.2",
    "release-it": "13.7.1",
    "typescript": "5.0.4"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "yarn lint && yarn typecheck"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json",
          "esm": true
        }
      ]
    ]
  }
}
